{
  "name": "flex-auto-counter",
  "version": "0.1.0",
  "description": "CLI that auto-fills incrementing Stencil values in Flex Add Serial Unit, with optional wait-for-serial mode.",
  "type": "module",
  "bin": {
    "flex-auto-counter": "./src/cli.js",
    "flexac": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "test": "node --test test/*.test.js",
    "demo": "node src/cli.js --dry-run --name \"USB Drive\" --count 5 --last 40",
    "demo:serial": "node src/cli.js --dry-run --with-serial --name \"USB Drive\" --count 3 --last 40",
    "test-form": "node src/serve-test-form.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "flex",
    "stencil",
    "serial",
    "counter",
    "automation",
    "cli"
  ],
  "license": "MIT"
}
